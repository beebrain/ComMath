\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mathstyle}[2026/05/01 Modern Math Style (Muted Pastel, Rounded, Drop Shadow)]

\RequirePackage{tikz}
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{skins,breakable,theorems}
\usepackage{amsmath, amsthm, amssymb}
\usepackage{fancybox} % ใช้สำหรับวาดกรอบวงรีโดยไม่พึ่ง tikz

%% ─────────────── New Macros for Examples ───────────────
%% Macro สำหรับวงรีล้อมรอบสมการแบบไม่ใช้ tikz (ใช้ ovalbox แทน)
\newcommand{\mathoval}[1]{%
  \ovalbox{\ensuremath{\displaystyle #1}}%
}

%% Environment สำหรับขั้นตอนวิธีทำ
\newenvironment{solsteps}{%
  \vspace{0.1em}
  \begin{list}{}{%
    \setlength{\topsep}{0.1em}
    \setlength{\itemsep}{0.1em}
    \setlength{\leftmargin}{1em}
    \setlength{\labelwidth}{0em}
    \setlength{\labelsep}{0em}
  }
}{%
  \end{list}
}

