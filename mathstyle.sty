%% ─────────────── Base Style Template ───────────────
\tcbset{
  mathstylebase/.style={
    enhanced jigsaw,
    breakable,
    drop fuzzy shadow,
    boxrule=0pt,          % Default no border
    arc=4pt,              % Rounded corners
    outer arc=4pt,
    left=12pt, right=12pt, top=10pt, bottom=10pt,
    before skip=14pt,
    after skip=14pt,
    fonttitle=\bfseries
  }
}

%% ── ทฤษฎีบท (thrm) ──────────────────────────────
\tcolorboxenvironment{thrm}{
  mathstylebase,
  colback=white,
  coltitle=thrmTitle,
  colframe=thrmBar,
  toprule=4pt,
  leftrule=4pt,
  rightrule=0pt,
  bottomrule=0pt
}

%% ── นิยาม (definition) ──────────────────────────
\tcolorboxenvironment{definition}{
  mathstylebase,
  colback=white,
  coltitle=defTitle,
  colframe=defBar,
  toprule=4pt,
  leftrule=4pt,
  rightrule=0pt,
  bottomrule=0pt
}

%% ── ตัวอย่าง (ex) ───────────────────────────────
\tcolorboxenvironment{ex}{
  blanker,
  breakable,
  left=0pt,
  before skip=14pt,
  after skip=14pt
}

%% ── บทแทรก (prop) ───────────────────────────────
\tcolorboxenvironment{prop}{
  mathstylebase,
  colback=white,
  coltitle=propTitle,
  colframe=propBar,
  toprule=4pt,
  leftrule=4pt,
  rightrule=0pt,
  bottomrule=0pt
}

%% ── หมายเหตุ (rem) ──────────────────────────────
\tcolorboxenvironment{rem}{
  mathstylebase,
  colback=white,
  coltitle=remTitle,
  colframe=remBar,
  toprule=4pt,
  leftrule=4pt,
  rightrule=0pt,
  bottomrule=0pt
}

%% ── บทสรุป (cor) ────────────────────────────────
\tcolorboxenvironment{cor}{
  mathstylebase,
  colback=white,
  coltitle=corTitle,
  colframe=corBar,
  toprule=4pt,
  leftrule=4pt,
  rightrule=0pt,
  bottomrule=0pt
}

%% ── คำเตือน (warning) ───────────────────────────
\tcolorboxenvironment{warning}{
  mathstylebase,
  colback=warnBg,
  coltitle=warnTitle,
  colframe=warnBar,
  toprule=4pt,
  leftrule=4pt,
  rightrule=0pt,
  bottomrule=0pt
}

%% ── แบบฝึกหัด (exercise) ────────────────────────
\tcolorboxenvironment{exercise}{
  blanker,
  breakable,
  left=0pt,
  before skip=14pt,
  after skip=14pt
}

%% ─────────────── Proof Environment ───────────────
\tcolorboxenvironment{proof}{
  enhanced jigsaw,
  breakable,
  colback=proofBg,
  colframe=proofBar,
  boxrule=0pt,
  leftrule=2pt,
  arc=0pt,
  outer arc=0pt,
  left=10pt, right=10pt, top=6pt, bottom=6pt,
  before skip=8pt,
  after skip=8pt,
}

%% ─────────────── QED Symbol ───────────────
\renewcommand{\qedsymbol}{$\blacksquare$}

%% ─────────────── Solution Environment ───────────────
\newenvironment{solution}{%
  \par\vspace{0.8em}
  \noindent\textbf{\color{black}วิธีทำ}\quad
  \begin{minipage}[t]{\dimexpr\textwidth-1.5cm\relax}
}{%
  \end{minipage}
  \par\vspace{1em}
  \noindent\textcolor{gray!40}{\rule{\textwidth}{0.5pt}}
  \par\vspace{1.5em}
}

\endinput
